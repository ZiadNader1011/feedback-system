generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("student")
  createdAt DateTime @default(now())

  feedbacks Feedback[]
}

model Feedback {
  id        Int      @id @default(autoincrement())
  message   String
  rating    Int
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])
}
